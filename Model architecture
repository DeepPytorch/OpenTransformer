import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.checkpoint import checkpoint

n_e = 256
layers = 30
block_repeats = 30 # Effective depth is layers * block_repeats

class MoELayer(nn.Module):
    def __init__(self, d_model, num_experts=n_e, k=2):
        super().__init__()
        self.experts = nn.ModuleList([nn.Sequential(
            nn.Linear(d_model, d_model * 4),
            nn.GELU(),
            nn.Linear(d_model * 4, d_model)
        ) for _ in range(num_experts)])
        
        self.router = nn.Linear(d_model, num_experts)
        self.k = k
        self.num_experts = num_experts
        self.last_aux_loss = 0.0

    def forward(self, x):
        b, s, d = x.shape
        logits = self.router(x)
        probs = F.softmax(logits, dim=-1)
        weights, indices = torch.topk(probs, self.k, dim=-1)
        
        # --- Load Balancing Loss (Auxiliary Loss) ---
        if self.training:
            top1_indices = indices[..., 0].flatten()
            fi = torch.bincount(top1_indices, minlength=self.num_experts).float() / top1_indices.numel()
            Pi = probs.view(-1, self.num_experts).mean(dim=0)
            self.last_aux_loss = self.num_experts * torch.sum(fi * Pi)

        # --- Vectorized Routing ---
        x_flat = x.view(-1, d)
        indices_flat = indices.view(-1, self.k)
        weights_flat = weights.view(-1, self.k)
        out_flat = torch.zeros_like(x_flat)

        for i in range(self.num_experts):
            mask = (indices_flat == i)
            if mask.any():
                token_indices, k_slots = torch.where(mask)
                expert_out = self.experts[i](x_flat[token_indices])
                out_flat[token_indices] += expert_out * weights_flat[token_indices, k_slots].unsqueeze(-1)
        
        return out_flat.view(b, s, d)


class TransformerMoELayer(nn.Module):
    def __init__(self, d_model, nhead):
        super().__init__()
        self.attn = nn.MultiheadAttention(d_model, nhead, batch_first=True)
        self.moe = MoELayer(d_model)
        self.norm1 = nn.LayerNorm(d_model)
        self.norm2 = nn.LayerNorm(d_model)

    def forward(self, x, is_causal=True):
        # Generate causal mask for autoregressive language modeling
        attn_mask = None
        if is_causal:
            seq_len = x.size(1)
            # Creates a triangular mask to prevent looking ahead
            attn_mask = nn.Transformer.generate_square_subsequent_mask(seq_len).to(x.device)

        # Attention + Residual
        attn_out, _ = self.attn(x, x, x, attn_mask=attn_mask, is_causal=is_causal)
        x = self.norm1(x + attn_out)
        
        # MoE + Residual
        x = self.norm2(x + self.moe(x))
        return x


class LoopTransformerMoE(nn.Module):
    def __init__(self, d_model, nhead, layers_per_block=layers, num_loops=block_repeats):
        super().__init__()
        self.block = nn.ModuleList([
            TransformerMoELayer(d_model, nhead)
            for _ in range(layers_per_block)
        ])
        self.num_loops = num_loops

    def forward(self, x):
        for _ in range(self.num_loops):
            for layer in self.block:
                # Use kwargs to pass the causal flag through gradient checkpointing
                x = checkpoint(layer, x, use_reentrant=False, is_causal=True)
        return x
    
    def get_total_aux_loss(self):
        total_loss = 0
        # Important: Multiply by num_loops since we pass through the block multiple times
        for layer in self.block:
            total_loss += layer.moe.last_aux_loss
        return total_loss * self.num_loops


# --- NEW: The Full Language Model Wrapper ---
class FullLoopedMoELM(nn.Module):
    def __init__(self, vocab_size, d_model=512, nhead=8, max_seq_len=2048):
        super().__init__()
        self.d_model = d_model
        
        # Token and Positional Embeddings
        self.token_emb = nn.Embedding(vocab_size, d_model)
        self.pos_emb = nn.Embedding(max_seq_len, d_model)
        
        self.backbone = LoopTransformerMoE(d_model, nhead)
        
        # Final LayerNorm and Language Modeling Head
        self.ln_f = nn.LayerNorm(d_model)
        self.lm_head = nn.Linear(d_model, vocab_size, bias=False)
        
        # Weight Tying 
        self.token_emb.weight = self.lm_head.weight

    def forward(self, idx, targets=None, aux_loss_weight=0.01):
        b, t = idx.size()
        
        # Generate positional indices
        pos = torch.arange(0, t, dtype=torch.long, device=idx.device)
        
        # Add token and positional embeddings
        x = self.token_emb(idx) + self.pos_emb(pos)
        
        # Pass through the looping MoE backbone
        x = self.backbone(x)
        
        # Final normalization and vocab projection
        x = self.ln_f(x)
        logits = self.lm_head(x)
        
        loss = None
        if targets is not None:
            # Main Cross-Entropy Loss
            ce_loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets.view(-1))
            
            # Retrieve MoE routing auxiliary loss
            aux_loss = self.backbone.get_total_aux_loss()
            
            # Combine losses
            loss = ce_loss + (aux_loss_weight * aux_loss)
            
        return logits, loss

def count_parameters(model):
    total = sum(p.numel() for p in model.parameters())
    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
    return total, trainable

