import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.checkpoint import checkpoint

# --- 1. CORE STABILITY & PERFORMANCE BLOCKS ---

class RMSNorm(nn.Module):
    def __init__(self, d_model, eps=1e-6):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(d_model))

    def forward(self, x):
        # RMSNorm is faster and more stable for ultra-deep models
        norm_x = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        return self.weight * norm_x

class SwiGLU(nn.Module):
    def __init__(self, d_model, d_ff):
        super().__init__()
        self.w1 = nn.Linear(d_model, d_ff)
        self.w2 = nn.Linear(d_model, d_ff)
        self.w3 = nn.Linear(d_ff, d_model)

    def forward(self, x):
        # SiLU(x1) * x2 -> The Llama 3 standard
        return self.w3(F.silu(self.w1(x)) * self.w2(x))

# --- 2. MULTI-HEAD LATENT ATTENTION (MLA) ---

class LatentAttention(nn.Module):
    def __init__(self, d_model, n_heads=32, latent_dim=512):
        super().__init__()
        self.n_heads = n_heads
        self.d_head = d_model // n_heads
        
        # KV Compression
        self.kv_compress = nn.Linear(d_model, latent_dim)
        self.kv_up = nn.Linear(latent_dim, d_model * 2) # Keys and Values
        
        # Query Projection
        self.q_proj = nn.Linear(d_model, d_model)

    def forward(self, x, mask=None):
        b, s, d = x.shape
        
        q = self.q_proj(x).view(b, s, self.n_heads, self.d_head).transpose(1, 2)
        
        # Compress and then decompress KV
        latent = self.kv_compress(x)
        kv = self.kv_up(latent).view(b, s, 2, self.n_heads, self.d_head)
        k, v = kv[:, :, 0], kv[:, :, 1]
        k = k.transpose(1, 2)
        v = v.transpose(1, 2)
        
        out = F.scaled_dot_product_attention(q, k, v, attn_mask=mask, is_causal=True)
        return out.transpose(1, 2).contiguous().view(b, s, d)

# --- 3. MOE WITH SHARED EXPERTS ---

class DeepMoE(nn.Module):
    def __init__(self, d_model, n_routed=240, n_shared=16, k=2):
        super().__init__()
        self.k = k
        # Routed Experts: High Specialization
        self.routed_experts = nn.ModuleList([SwiGLU(d_model, d_model*2) for _ in range(n_routed)])
        # Shared Experts: General Knowledge (Always Active)
        self.shared_experts = nn.ModuleList([SwiGLU(d_model, d_model*2) for _ in range(n_shared)])
        
        self.router = nn.Linear(d_model, n_routed)

    def forward(self, x):
        b, s, d = x.shape
        x_flat = x.view(-1, d)
        
        # 1. Compute Shared Experts (All tokens pass through these)
        shared_out = sum(expert(x) for expert in self.shared_experts)
        
        # 2. Compute Routed Experts
        logits = self.router(x_flat)
        probs = F.softmax(logits, dim=-1)
        weights, indices = torch.topk(probs, self.k, dim=-1)
        
        routed_out = torch.zeros_like(x_flat)
        for i in range(len(self.routed_experts)):
            mask = (indices == i)
            if mask.any():
                token_idx, _ = torch.where(mask)
                routed_out[token_idx] += self.routed_experts[i](x_flat[token_idx])
        
        return shared_out + routed_out.view(b, s, d)

# --- 4. THE FULL LOOPED TRANSFORMER ---

class FrontierBlock(nn.Module):
    def __init__(self, d_model, n_heads):
        super().__init__()
        self.attn = LatentAttention(d_model, n_heads)
        self.moe = DeepMoE(d_model)
        self.norm1 = RMSNorm(d_model)
        self.norm2 = RMSNorm(d_model)

    def forward(self, x):
        x = x + self.attn(self.norm1(x))
        x = x + self.moe(self.norm2(x))
        return x

class UltraLoopTransformer(nn.Module):
    def __init__(self, vocab_size, d_model=8192, layers=30, loops=30):
        super().__init__()
        self.token_emb = nn.Embedding(vocab_size, d_model)
        self.block = nn.ModuleList([FrontierBlock(d_model, 64) for _ in range(layers)])
        self.loops = loops
        self.output = nn.Linear(d_model, vocab_size)

    def forward(self, idx):
        # Initial Embedding
        x = self.token_emb(idx)
        recall_tensor = x # Store original input for Recall Injection
        
        for loop_idx in range(self.loops):
            # Recall Injection: Add original signal to prevent "forgetting"
            # Scaled by loop depth to maintain stability
            x = x + (recall_tensor * (1.0 / (loop_idx + 1)))
            
            for layer in self.block:
                # Gradient checkpointing is mandatory at this scale
                x = checkpoint(layer, x, use_reentrant=False)
                
        return self.output(x)

